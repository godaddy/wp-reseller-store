{
  "name": "reseller-store",
  "title": "GoDaddy Reseller Store",
  "description": "Resell hosting, domains, and more right from your WordPress site.",
  "version": "2.2.17",
  "author": "GoDaddy",
  "license": "GPL-2.0",
  "repository": "godaddy/wp-reseller-store",
  "homepage": "https://wordpress.org/plugins/reseller-store/",
  "bugs": {
    "url": "https://github.com/godaddy/wp-reseller-store/issues"
  },
  "engines": {
    "node": ">= 18.0.0",
    "php": ">= 8.1",
    "wordpress": ">= 6.2"
  },
  "scripts": {
    "sass": "sass .dev/sass/store.scss:assets/css/store.css .dev/sass/admin.scss:assets/css/admin.css --no-source-map",
    "sass:min": "sass .dev/sass/store.scss:assets/css/store.min.css .dev/sass/admin.scss:assets/css/admin.min.css --style=compressed --no-source-map",
    "rtlcss": "rtlcss assets/css/store.css assets/css/store-rtl.css && rtlcss assets/css/admin.css assets/css/admin-rtl.css && rtlcss assets/css/store.min.css assets/css/store-rtl.min.css && rtlcss assets/css/admin.min.css assets/css/admin-rtl.min.css",
    "css": "npm run sass && npm run sass:min && npm run rtlcss",
    "js": "webpack",
    "lint": "eslint .dev/src/",
    "imagemin": "imagemin assets/images/**/*.{jpg,jpeg,png,gif,svg} --plugin=pngquant --out-dir=assets/images",
    "pot": "wp-pot --src 'reseller-store.php' --src 'includes/**/*.php' --dest-file 'languages/reseller-store.pot' --package 'Reseller Store' --domain 'reseller-store' --bug-report 'https://github.com/godaddy/wp-reseller-store/issues'",
    "clean": "rimraf build/",
    "copy:build": "copyfiles -u 0 \"reseller-store.php\" \"index.php\" \"class-plugin.php\" \"*.txt\" \"assets/**\" \"includes/**\" \"languages/*.{mo,pot}\" \"lib/**\" build/",
    "prebuild": "npm run js && npm run css",
    "build": "npm run clean && npm run copy:build",
    "version": "node -e \"const pkg=require('./package.json'); const fs=require('fs'); ['reseller-store.php','class-plugin.php'].forEach(f => { let c=fs.readFileSync(f,'utf8'); c=c.replace(/(Version:\\s*?)[a-zA-Z0-9.+-]+$/m, '$1'+pkg.version); c=c.replace(/VERSION(\\s*?)=(\\s*?['\"])[a-zA-Z0-9.+-]+/g, 'VERSION$1=$2'+pkg.version); fs.writeFileSync(f,c); });\" && git add -A ."
  },
  "dependencies": {
    "domain-search": "^5.0.1"
  },
  "devDependencies": {
    "@wordpress/eslint-plugin": "^25.0.0",
    "@babel/core": "^7.21.8",
    "@babel/preset-env": "^7.21.5",
    "@babel/preset-react": "^7.18.6",
    "autoprefixer": "^10.4.14",
    "babel-loader": "^9.1.2",
    "babel-plugin-syntax-async-functions": "^6.13.0",
    "babel-plugin-transform-class-properties": "6.24.1",
    "babel-plugin-transform-object-rest-spread": "^6.26.0",
    "babel-plugin-transform-react-jsx": "^6.24.1",
    "babel-plugin-transform-runtime": "^6.23.0",
    "copyfiles": "^2.4.1",
    "css-loader": "^6.7.4",
    "eslint": "^10.0.0",
    "imagemin-cli": "^7.0.0",
    "imagemin-pngquant": "^9.0.2",
    "mini-css-extract-plugin": "^2.7.6",
    "postcss-loader": "^7.3.0",
    "raw-loader": "^4.0.2",
    "rimraf": "^5.0.1",
    "rtlcss": "^4.1.1",
    "sass": "^1.62.1",
    "sass-loader": "^13.3.0",
    "style-loader": "^3.3.3",
    "webpack": "^5.83.1",
    "webpack-cli": "^5.1.1",
    "wp-pot": "^1.4.1"
  }
}
