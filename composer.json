{
    "name": "godaddy/wp-reseller-store",
    "description": "",
    "homepage": "https://www.godaddy.com/en-uk/reseller-program",
    "license": "GPL-2.0",
    "support": {
        "issues": "https://github.com/godaddy/wp-reseller-store/issues"
    },
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "yoast/phpunit-polyfills": "^2.0",
        "squizlabs/php_codesniffer": "^3.9",
        "wp-coding-standards/wpcs": "^3.1",
        "phpcsstandards/phpcsutils": "^1.0"
    },
    "scripts": {
        "test": "./vendor/bin/phpunit -c .dev/phpunit.xml.dist",
        "phpcs": "./vendor/bin/phpcs -n --standard=.dev/phpcs.ruleset.xml .",
        "setup-wpcs": "vendor/bin/phpcs --config-set installed_paths vendor/wp-coding-standards/wpcs"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
